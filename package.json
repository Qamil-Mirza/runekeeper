{
  "name": "runekeeper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "node --env-file=.env --import=tsx/esm server.ts",
    "build": "next build && npx esbuild server.ts --bundle --platform=node --target=node20 --outfile=.next/standalone/server-custom.js --packages=external",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@google/generative-ai": "^0.24.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.12.1",
    "langfuse": "^3.38.6",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.4",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.4",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0"
  }
}
