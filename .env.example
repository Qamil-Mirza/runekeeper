# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/runekeeper
# Used by docker-compose.prod.yml for the Postgres container and app DATABASE_URL
POSTGRES_PASSWORD=postgres

# ─── Token Encryption (32 bytes = 64 hex chars) ──────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Google Gemini (Cloud LLM) ────────────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional: override model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
# Optional: override voice model (default: gemini-2.0-flash-live-001)
# GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log level: "debug" in dev, "info" or "warn" in production
LOG_LEVEL=debug

# ─── Gmail Integration (Pub/Sub) ───────────────────────────────────────────
# Shared secret for verifying Pub/Sub webhook requests
# GMAIL_WEBHOOK_SECRET=
# Google Cloud project ID for Pub/Sub topic
# GCP_PROJECT_ID=
# Pub/Sub topic name (default: runekeeper-gmail)
# GMAIL_PUBSUB_TOPIC=runekeeper-gmail

# ─── Langfuse LLM Tracing (optional) ────────────────────────────────────────
# Sign up at https://cloud.langfuse.com or self-host
# Tracing is disabled when these are not set
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
