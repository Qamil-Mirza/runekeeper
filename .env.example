# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/runekeeper

# ─── Token Encryption (32 bytes = 64 hex chars) ──────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Ollama (Local LLM) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
# Fast model for simple queries (greetings, acks). Pull with: ollama pull qwen3:1.7b
OLLAMA_MODEL_FAST=qwen3:1.7b
# Context window size — lower values save VRAM (default 4096 is enough for this app)
OLLAMA_NUM_CTX=4096
